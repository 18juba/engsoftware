{
  "title": "AuthService — Visão Geral",
  "uid": "auth-service-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requisições por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"auth-service\"}[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tempo de resposta (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"auth-service\"}[1m]))",
          "legendFormat": "p99 {{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de erros (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"auth-service\", status=~\"5..\"}[1m])",
          "legendFormat": "{{status}} {{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uso de memória",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"auth-service\"} / 1024 / 1024",
          "legendFormat": "MB em uso"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total de requisições",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"auth-service\"})",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Uptime (segundos)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"auth-service\"}",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "id": 7,
      "title": "Goroutines ativas",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "go_goroutines{job=\"auth-service\"}",
          "legendFormat": "Goroutines"
        }
      ]
    },
    {
      "id": 8,
      "title": "Status do banco de dados",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"auth-service\"}",
          "legendFormat": "Service up"
        }
      ]
    }
  ]
}